    "bugs":  {
                 "url":  "https://github.com/BlackiePiggy/BlackiePiggy.github.io/issues"
             },
    "homepage":  "https://github.com/BlackiePiggy/BlackiePiggy.github.io#readme",
    "devDependencies":  {
                            "js-yaml":  "^4.1.1"
                        }
}
