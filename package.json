{
    "name":  "hugo-blox-academic-cv-starter",
    "version":  "1.0.0",
    "private":  true,
    "packageManager":  "pnpm@10.14.0",
    "description":  "Academic CV starter template for Hugo Blox with Tailwind CSS v4",
    "scripts":  {
                    "dev":  "hugo server --disableFastRender",
                    "build":  "hugo --minify",
                    "cms:generate":  "node scripts/generate-decap-config.cjs \u0026\u0026 node scripts/generate-publisher-templates.cjs",
                    "publisher:generate":  "node scripts/generate-publisher-templates.cjs",
                    "publisher:local-api":  "node scripts/local-publish-server.cjs"
                },
    "dependencies":  {
                         "@tailwindcss/cli":  "^4.1.12",
                         "@tailwindcss/typography":  "^0.5.10",
                         "autoprefixer":  "^10.4.21",
                         "postcss":  "^8.5.6",
                         "tailwindcss":  "^4.1.12"
                     },
    "main":  "index.js",
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/BlackiePiggy/BlackiePiggy.github.io.git"
                   },
    "keywords":  [

                 ],
